parameters:
    level: 6
    paths:
        - src
        - tests
    
    # Only ignore specific patterns that are still needed
    ignoreErrors:
        # PHPStan template type errors for expect() in tests
        - '#Unable to resolve the template type TValue in call to function expect#'
        # Ignore dynamic property access in DTOs (they use magic methods)
        - '#Access to an undefined property .*DTO::\$.*#'
        - '#Call to an undefined method .*DTO::get.*#'
        - '#Call to an undefined method .*DTO::set.*#'
        # Allow unsafe usage of new static() in DTOs
        - '#Unsafe usage of new static\(\)#'
        # Ignore property access issues in tests (test files often access properties dynamically)
        - '#Access to an undefined property Grazulex\\Arc\\Contracts\\DTOInterface::\$.*#'
        # Ignore return type issues in factory trait (trait methods return DTOInterface but we want static)
        - '#Method .*::(fake|fakeMany)\(\) should return .* but returns .*DTOInterface.*#'
    
    # Exclude files (examples and demo files don't need strict analysis)
    excludePaths:
        - tests/Pest.php
        - vendor
        - src/Examples/
    
    # Include Laravel stubs
    bootstrapFiles:
        - vendor/autoload.php

